# AgentHub — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── HTTP ──────────────────────────────────────────────────────────────────────
AGENTHUB_HTTP_ADDR=0.0.0.0:8093

# ── Database ──────────────────────────────────────────────────────────────────
AGENTHUB_DB_PATH=data/agenthub.db

# ── Security (generate with: openssl rand -hex 32) ───────────────────────────
AGENTHUB_SECRET_KEY=CHANGE_ME_32_byte_hex_openssl_rand_hex_32
AGENTHUB_JWT_SECRET=CHANGE_ME_at_least_32_chars_random_string

# ── Development (set to false in production) ──────────────────────────────────
AGENTHUB_DEV=false
AGENTHUB_DEV_BYPASS_TOTP=false

# ── WhatsApp ──────────────────────────────────────────────────────────────────
AGENTHUB_WA_ENABLED=false
# Your WhatsApp number in international format (e.g. 15551234567)
AGENTHUB_WA_NOTIFY_PHONE=

# ── AI Engine ─────────────────────────────────────────────────────────────────
AGENTHUB_DEFAULT_ENGINE=claude
AGENTHUB_DEFAULT_MODEL=claude-sonnet-4-5

# ── Logging ───────────────────────────────────────────────────────────────────
AGENTHUB_LOG_LEVEL=info

# ── Cookie ────────────────────────────────────────────────────────────────────
# Set to true when serving over HTTPS
AGENTHUB_COOKIE_SECURE=false
