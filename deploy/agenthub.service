[Unit]
Description=AgentHub — asistente personal por WA + Web (mini PC agente)
Documentation=https://github.com/snestors/agenthub
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
User=nestor
Group=nestor
WorkingDirectory=/home/nestor/agenthub
EnvironmentFile=/home/nestor/agenthub/.env
ExecStart=/home/nestor/agenthub/bin/agenthub serve
Restart=always
RestartSec=10s
KillSignal=SIGTERM
TimeoutStopSec=20s

# Hardening (modesto — single-user box)
# NoNewPrivileges=true  # disabled to allow sudo systemctl via NOPASSWD for service_action
PrivateTmp=true
ProtectSystem=full
ProtectHome=false
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

# Logs
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agenthub

[Install]
WantedBy=multi-user.target
